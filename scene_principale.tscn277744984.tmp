[sub_resource type="GDScript" id="GDScript_64ilw"]
script/source = "extends Label # Ce script est SUR le Label, donc \"text\" marche direct

var score = 0

func _ready():
	# Initialisation
	text = \"Clicks: 0\"

# Fonction qui fait apparaître une cible
func spawn_cible():
	var nouvelle_cible = load(\"res://cible.tscn\").instantiate()
	
	# ATTENTION : Si tu ajoutes la cible comme enfant du Label, ça peut être bizarre visuellement.
	# Il vaut mieux l'ajouter à la racine de la scène ou un dossier \"Ennemis\".
	# get_parent().add_child(nouvelle_cible) serait plus propre si le script est sur le Label.
	add_child(nouvelle_cible) 
	
	nouvelle_cible.clicked.connect(_on_cible_clicked)

# La fonction qui reçoit le signal
func _on_cible_clicked():
	score += 1
	text = \"Clicks: \" + str(score) # On modifie directement NOTRE texte
	print(\"Score augmenté !\")
"

